# ==== Banco de dados (Neon) ====
# Conexão usada pela API em runtime (pode ser a pooled da Neon).
DATABASE_URL=postgresql://user:password@host/db?sslmode=require
# Conexão DIRETA (sem pooler) — usada para migrations. Na Neon, use a "Direct connection".
DIRECT_DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# ==== Segurança ====
# Obrigatório em produção e deve ter no mínimo 32 caracteres.
# Gere um: openssl rand -base64 48
JWT_SECRET=troque-por-uma-string-aleatoria-de-32-mais-caracteres

# ==== Ambiente ====
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Origens permitidas no CORS (separadas por vírgula). Use o domínio do front.
CORS_ORIGIN=https://app.seudominio.com

# ==== Rate limit ====
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW=1 minute

# ==== Health check público ====
PUBLIC_HEALTH=true

# ==== Reverse proxy (Caddy) ====
# Domínio que o Caddy vai servir com HTTPS automático.
DOMAIN=api.seudominio.com

# ==== Imagem Docker (produção) ====
# Imagem publicada pelo CD no GitHub Container Registry. Ajuste para o seu repo.
API_IMAGE=ghcr.io/SEU_USUARIO/agendamentoapi:latest

# ==== Redis (futuro worker de WhatsApp / BullMQ) ====
REDIS_URL=redis://redis:6379

# ===== API (Fastify) — exemplo de ambiente =====
# Copie para `.env` (local) ou crie na VPS com os valores reais. NUNCA commitar o .env real.

# --- Banco (Neon) ---
# Connection string (pode ser a *pooled*). Em produção, da branch principal.
DATABASE_URL="postgresql://user:pass@host/db?schema=public"
# Direct connection (sem pooler) — usada pelas migrations.
DIRECT_DATABASE_URL="postgresql://user:pass@host/db"

# --- Auth / sessão ---
# Obrigatório em produção; mínimo 32 caracteres. Gere com: openssl rand -base64 48
JWT_SECRET="troque-por-um-segredo-forte-com-32-mais-caracteres"
# Validade da sessão (curta por segurança). Default do código: 2d.
JWT_EXPIRES_IN="2d"
# Cookie SameSite: "lax" (mesma-site/subdomínios), "strict" ou "none" (cross-site, força secure).
COOKIE_SAMESITE="lax"
# Domínio do cookie de sessão. Em produção com subdomínios (app./api.), use ".seudominio.com"
# para o cookie ser compartilhado entre Web e API (e legível pelo gate de rota do Web). Em dev
# (localhost), deixe vazio (cookie host-only — o localhost já é compartilhado entre portas).
COOKIE_DOMAIN=".seudominio.com"

# --- Servidor ---
NODE_ENV="production"
HOST="0.0.0.0"
PORT="3000"
# Origem(ns) permitida(s) do front (CORS). Em produção: o domínio do Web.
CORS_ORIGIN="https://app.seudominio.com"
RATE_LIMIT_MAX="120"
RATE_LIMIT_WINDOW="1 minute"
PUBLIC_HEALTH="true"
# Base do app Web — monta os links de verificação/reset enviados por email.
APP_BASE_URL="https://app.seudominio.com"

# --- Anti-brute-force (lockout) ---
LOGIN_MAX_ATTEMPTS="5"
LOGIN_LOCK_MINUTES="15"

# --- Cloudinary (upload assinado; opcional) ---
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_UPLOAD_FOLDER=""
CLOUDINARY_ALLOWED_FORMATS="jpg,png,webp"

# --- Email transacional (Resend; opcional — sem chave, loga o link em dev) ---
RESEND_API_KEY=""
RESEND_FROM="no-reply@seudominio.com"

# --- Observabilidade (Sentry; opcional — sem DSN = desligado/no-op) ---
SENTRY_DSN=""
SENTRY_ENVIRONMENT="production"            # default: NODE_ENV
SENTRY_RELEASE=""                          # SHA do deploy (correlaciona erro <-> versão)
SENTRY_TRACES_SAMPLE_RATE="0.1"            # 0..1; default dev 1.0 / prod 0.1

# ===== Deploy (docker-compose na VPS) =====
# Imagens publicadas no GHCR pelo CI (convenção <owner>/<repo>-api e -web).
API_IMAGE="ghcr.io/SEU_OWNER/SEU_REPO-api:latest"
WEB_IMAGE="ghcr.io/SEU_OWNER/SEU_REPO-web:latest"
# Domínios roteados pelo Caddy (HTTPS automático). DNS A-record -> IP da VPS.
API_DOMAIN="api.seudominio.com"
WEB_DOMAIN="app.seudominio.com"

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  STAFF
  CUSTOMER
}

/// Vertical do tenant — gate de módulos opcionais (ex.: odontologia só em DENTAL).
enum BusinessType {
  GENERIC
  DENTAL
}

model Tenant {
  id                     Int                     @id @default(autoincrement())
  name                   String
  slug                   String                  @unique
  // Vertical do tenant (gate de módulos opcionais). Default preserva os tenants atuais.
  businessType           BusinessType            @default(GENERIC)
  // Settings
  allowCustomerBooking   Boolean                 @default(false)
  timezone               String                  @default("America/Sao_Paulo")
  slotIntervalMinutes    Int                     @default(15)
  minLeadTimeMinutes     Int                     @default(0)
  maxAdvanceDays         Int                     @default(90)
  // Triagem de status: minutos após o início p/ "aguardando definição" e após o fim p/ "passado".
  statusPromptAfterStartMin Int                  @default(0)
  overdueAfterEndMin     Int                     @default(60)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  users                  User[]
  services               Service[]
  appointments           Appointment[]
  patients               Patient[]
  businessHours          BusinessHours[]
  businessDateOverrides  BusinessDateOverride[]
}

/// Paciente/cliente do tenant (genérico — serve qualquer nicho). Fundação do histórico.
/// Criado/atualizado por auto-upsert em (tenantId, phone) no booking.
model Patient {
  id           Int           @id @default(autoincrement())
  tenantId     Int
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  phone        String        // normalizado (só dígitos)
  email        String?
  birthDate    DateTime?
  notes        String?
  appointments Appointment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([tenantId, phone])
  @@index([tenantId])
}

model User {
  id           Int           @id @default(autoincrement())
  email        String
  name         String?
  passwordHash String
  role         Role          @default(CUSTOMER)
  tenantId     Int
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  // Anti-brute-force: tentativas de login falhas e bloqueio temporário da conta.
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  // Verificação de email (null = ainda não verificado).
  emailVerifiedAt     DateTime?
  authTokens          AuthToken[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([email, tenantId])
  @@index([tenantId])
  @@index([email])
}

enum AuthTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

// Token de verificação de email / reset de senha. Guarda só o HASH do token (o valor cru vai no
// link do email); uso único (usedAt) e com expiração. Vazamento do banco não expõe token usável.
model AuthToken {
  id        Int           @id @default(autoincrement())
  tokenHash String        @unique
  type      AuthTokenType
  userId    Int
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime      @default(now())

  @@index([userId])
}

model Service {
  id                Int           @id @default(autoincrement())
  name              String
  description       String?
  imageUrl          String?
  priceInCents      Int
  durationInMinutes Int
  tenantId          Int
  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments      Appointment[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([tenantId])
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  NO_SHOW
  CANCELED
}

model Appointment {
  id            Int               @id @default(autoincrement())
  customerName  String
  customerPhone String
  customerEmail String?
  notes         String?
  serviceId     Int
  service       Service           @relation(fields: [serviceId], references: [id])
  userId        Int?
  user          User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  patientId     Int?
  patient       Patient?          @relation(fields: [patientId], references: [id], onDelete: SetNull)
  teeth         AppointmentTooth[]
  tenantId      Int
  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  startTime     DateTime
  endTime       DateTime
  status        AppointmentStatus @default(SCHEDULED)
  version       Int               @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([tenantId, serviceId])
  @@index([tenantId, startTime, endTime])
  @@index([tenantId, userId])
  @@index([tenantId, patientId])
  @@index([serviceId])
}

/// Procedimento odontológico registrado por dente (vocabulário fixo do MVP).
/// Aditivo: novo procedimento = +1 valor + migration. OUTRO + nota cobre casos fora da lista.
enum DentalProcedure {
  AVALIACAO
  PROFILAXIA
  RESTAURACAO
  ENDODONTIA
  EXTRACAO
  COROA
  PROTESE
  IMPLANTE
  CLAREAMENTO
  RASPAGEM
  SELANTE
  FLUOR
  RADIOGRAFIA
  OUTRO
}

/// Dente tratado numa consulta (charting por consulta, notação FDI/ISO 3950). Só em tenant DENTAL.
/// 1 registro por dente por consulta (@@unique); replace-on-edit no service. Aditivo, não polui o core.
model AppointmentTooth {
  id            Int             @id @default(autoincrement())
  appointmentId Int
  appointment   Appointment     @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  toothFdi      Int             // FDI/ISO 3950: 11-18,21-28,31-38,41-48 (perm.) · 51-85 (decíduos)
  procedure     DentalProcedure
  note          String?
  createdAt     DateTime        @default(now())

  @@unique([appointmentId, toothFdi])
  @@index([appointmentId])
}

model BusinessHours {
  id        Int             @id @default(autoincrement())
  dayOfWeek Int
  openTime  String
  closeTime String
  isOff     Boolean         @default(false)
  tenantId  Int
  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  breaks    BusinessBreak[]

  @@unique([tenantId, dayOfWeek])
  @@index([tenantId])
}

model BusinessBreak {
  id              Int           @id @default(autoincrement())
  businessHoursId Int
  businessHours   BusinessHours @relation(fields: [businessHoursId], references: [id], onDelete: Cascade)
  startTime       String
  endTime         String
  label           String?

  @@index([businessHoursId])
}

// Idempotency-Key do booking: evita criar agendamento duplicado em retry/duplo-clique.
// A primeira requisição "reivindica" a (tenantId, key) via índice único; replays devolvem
// o agendamento já criado (appointmentId).
model IdempotencyKey {
  id            Int      @id @default(autoincrement())
  key           String
  tenantId      Int
  appointmentId Int?
  createdAt     DateTime @default(now())

  @@unique([tenantId, key])
  @@index([tenantId])
}

model BusinessDateOverride {
  id        Int      @id @default(autoincrement())
  date      String   // YYYY-MM-DD
  openTime  String?
  closeTime String?
  isOff     Boolean  @default(false)
  tenantId  Int
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, date])
  @@index([tenantId])
}
